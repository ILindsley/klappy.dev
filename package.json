  "dependencies": {
    "marked": "^17.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "fast-glob": "^3.3.3",
    "husky": "^9.1.7",
    "puppeteer": "^24.35.0",
    "vite": "^6.0.7"
  }
